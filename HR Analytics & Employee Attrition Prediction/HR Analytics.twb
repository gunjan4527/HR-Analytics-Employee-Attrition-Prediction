        <calculation class='tableau' formula='IF [Attrition] = &quot;Yes&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Attrition Rate' datatype='real' name='[Calculation_1794469446144001]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1794469445222400]) / COUNT([Calculation_1794469445222400])' />
      </column>
      <column caption='Attrition Cost Estimate' datatype='real' name='[Calculation_1794469446373378]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [Attrition] = &quot;Yes&quot; THEN [MonthlyIncome] * 12 * 1.5&#13;&#10;ELSE 0&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='Attrition Risk Score' datatype='real' name='[Calculation_1794469446656003]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;IF [OverTime] = &quot;Yes&quot; THEN 1 ELSE 0 END +&#13;&#10;IF [JobSatisfaction] &lt;= 2 THEN 1 ELSE 0 END +&#13;&#10;IF [YearsAtCompany] &lt;= 2 THEN 1 ELSE 0 END +&#13;&#10;IF [MonthlyIncome] &lt; 3000 THEN 1 ELSE 0 END&#13;&#10;) / 4' />
      </column>
      <column caption='Risk Label' datatype='string' name='[Calculation_1794469447761924]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1794469446656003] &gt;= 0.65 THEN &quot;High Risk&quot;&#13;&#10;ELSEIF [Calculation_1794469446656003] &gt;= 0.35 THEN &quot;Medium Risk&quot;&#13;&#10;ELSE &quot;Low Risk&quot;&#13;&#10;END' />
      </column>
      <column caption='Attrition Cost' datatype='real' name='[Calculation_1794469733654535]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [Attrition] = &quot;Yes&quot;&#13;&#10;THEN [MonthlyIncome]*12*1.5&#13;&#10;ELSE 0 END&#13;&#10;)' />
      </column>
      <column caption='Headcount' datatype='integer' name='[Calculation_1794469734006792]' role='measure' type='quantitative'>
